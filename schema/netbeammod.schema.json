{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/BeamMP/BeamNG-Mod-Registry/main/schema/netbeammod.schema.json",
  "title": "NetBeamMod Template",
  "description": "Template for automatic .beammod generation from upstream sources. The inflator fetches releases, computes hashes, and generates full .beammod files.",
  "type": "object",
  "required": ["spec_version", "identifier", "name", "abstract", "author", "license", "$kref"],
  "properties": {
    "$kref": {
      "type": "string",
      "pattern": "^#/(github/[^/]+/.+|beamng/[0-9]+)$",
      "description": "Source reference. Supported: #/github/{owner}/{repo} or #/beamng/{resource_id}"
    },
    "$filter_asset": {
      "type": "string",
      "description": "Regex to match the desired release asset filename. If omitted, the first .zip asset is used."
    },
    "$version_strip_v": {
      "type": "boolean",
      "default": true,
      "description": "Strip leading 'v' from version tags (default: true)."
    },
    "$version_transform": {
      "type": "object",
      "properties": {
        "match": { "type": "string", "description": "Regex pattern to match in the version string." },
        "replace": { "type": "string", "description": "Replacement string (supports $1, $2 capture groups)." }
      },
      "required": ["match", "replace"],
      "description": "Regex find/replace applied to the version string after $version_strip_v."
    },
    "$include_prerelease": {
      "type": "boolean",
      "default": false,
      "description": "Include GitHub pre-releases (default: false)."
    },
    "$max_releases": {
      "type": "integer",
      "minimum": 1,
      "default": 10,
      "description": "Maximum number of releases to process (newest first, default: 10)."
    },
    "spec_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Spec version. Currently 1."
    },
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$",
      "minLength": 2,
      "maxLength": 128
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "abstract": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "author": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 }
      ]
    },
    "license": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      ]
    },
    "kind": {
      "type": "string",
      "enum": ["package", "metapackage", "dlc"],
      "default": "package"
    },
    "mod_type": {
      "type": "string",
      "enum": ["vehicle", "map", "skin", "ui_app", "sound", "license_plate", "scenario", "automation", "other"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 64 },
      "uniqueItems": true
    },
    "description": {
      "type": "string",
      "maxLength": 16384
    },
    "release_status": {
      "type": "string",
      "enum": ["stable", "testing", "development"],
      "default": "stable"
    },
    "beamng_version": { "type": "string" },
    "beamng_version_min": { "type": "string" },
    "beamng_version_max": { "type": "string" },
    "beammp_version_min": { "type": "string" },
    "multiplayer_scope": {
      "type": "string",
      "enum": ["client", "server", "both"],
      "default": "client"
    },
    "install": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "file": { "type": "string" },
          "find": { "type": "string" },
          "find_regexp": { "type": "string" },
          "install_to": { "type": "string" },
          "as": { "type": "string" },
          "filter": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ]
          },
          "filter_regexp": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ]
          },
          "include_only": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ]
          },
          "include_only_regexp": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ]
          },
          "find_matches_files": { "type": "boolean", "default": false }
        },
        "required": ["install_to"],
        "oneOf": [
          { "required": ["file"] },
          { "required": ["find"] },
          { "required": ["find_regexp"] }
        ]
      }
    },
    "depends": { "$ref": "#/definitions/relationship_list" },
    "recommends": { "$ref": "#/definitions/relationship_list" },
    "suggests": { "$ref": "#/definitions/relationship_list" },
    "supports": { "$ref": "#/definitions/relationship_list" },
    "conflicts": { "$ref": "#/definitions/relationship_list" },
    "provides": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$" },
      "uniqueItems": true
    },
    "replaced_by": { "$ref": "#/definitions/relationship" },
    "resources": {
      "type": "object",
      "properties": {
        "homepage": { "type": "string", "format": "uri" },
        "repository": { "type": "string", "format": "uri" },
        "bugtracker": { "type": "string", "format": "uri" },
        "beamng_resource": { "type": "string", "format": "uri" },
        "beammp_forum": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "thumbnail": { "type": "string", "format": "uri" },
    "comment": { "type": "string", "maxLength": 4096 },
    "localizations": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "abstract": { "type": "string" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "definitions": {
    "relationship": {
      "type": "object",
      "properties": {
        "identifier": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$" },
        "min_version": { "type": "string" },
        "max_version": { "type": "string" },
        "version": { "type": "string" }
      },
      "required": ["identifier"]
    },
    "any_of_relationship": {
      "type": "object",
      "properties": {
        "any_of": {
          "type": "array",
          "items": { "$ref": "#/definitions/relationship" },
          "minItems": 1
        },
        "choice_help_text": { "type": "string" }
      },
      "required": ["any_of"]
    },
    "relationship_list": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "#/definitions/relationship" },
          { "$ref": "#/definitions/any_of_relationship" }
        ]
      }
    }
  },
  "patternProperties": {
    "^x_": {
      "description": "Extension fields for third-party tooling."
    }
  },
  "additionalProperties": false
}
